{
  "name": "vue-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "api": "json-server --watch db.json --port 3000",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css}\"",
    "start": "concurrently \"npm run api\" \"npm run dev\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "datatables.net-dt": "^2.3.7",
    "datatables.net-vue3": "^3.0.4",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "json-server": "^1.0.0-beta.13",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
